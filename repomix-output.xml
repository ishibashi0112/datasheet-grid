  | { type: 'selection/update'; cell: CellCoord }
  | { type: 'rowSelection/start'; row: number }
  | { type: 'rowSelection/update'; row: number }
  | { type: 'columnSelection/start'; col: number }
  | { type: 'columnSelection/update'; col: number }
