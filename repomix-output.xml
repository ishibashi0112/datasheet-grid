<file path="src/components/spreadsheet-grid/styles.css">
/* SpreadsheetGrid のスタイル。
   方針(THEME-1 で @layer を撤去し未レイヤー化):
   - 旧 @layer ssg-base は Tailwind v3 preflight(未レイヤーの `* { border-width: 0 }` 等)に
     特異度無関係で必ず負け、罫線・枠線が消える致命的な共存問題がありました(CSS カスケードでは
     未レイヤー > レイヤー)。未レイヤーの単一クラス(特異度 (0,1,0))なら preflight
     (`*` / 要素セレクタ = (0,0,1) 以下)に構造的に勝ちます。Tailwind v4 の preflight は
     レイヤー内のため、未レイヤーの本 CSS が常に勝ちます。
   - デザイントークンは CSS 変数(--ssg-*)。定義は :where(.ssg-root)(特異度 0)に置くため、
     利用側のトークン上書きは読み込み順に依らず必ず勝ちます(テーマ変更の主 API)。
   - プロパティ上書きは同特異度なら読み込み順依存です。確実にするには
     `.ssg-body-cell.my-class` のように基底クラスと連結してください(README「Styles」参照)。
     Tailwind v4 で utilities を優先したい場合は `@import "...style.css" layer(components);`
     または @layer ssg-base 版の style.layer.css を使います。
   - 動的に決まる値(座標 / 解決済み列幅 / オーバーレイ位置など)は引き続きインライン style です。
   - トークンは .ssg-root にスコープし、グローバル(:root)を汚しません。
   - 注記: ルール本体の 2 スペースインデントは旧 @layer ブロック時代の名残です(diff 最小化のため
     維持。CSS 上は無害)。 */

  /* デザイントークン(既定値)。:where は特異度 0 — 利用側の `.ssg-root { --ssg-accent: ... }`
     等の上書きが読み込み順に依らず必ず勝ちます。
     セレクタリストについて(TH-DK-1): popover / menu / filter popover / ドラッグゴーストは
     document.body 直下のポータルで .ssg-root の継承が届かないため、各ポータル root にも
     同じトークンを直接定義します(テーマ切替はこのリストへ修飾子を足すだけで全面に効きます)。 */
  :where(.ssg-root, .ssg-popover, .ssg-menu-panel, .ssg-filter-popover, [data-grid-drag-ghost], .ssg-tooltip) {
    /* ネイティブ UI(スクロールバー / select 等)の描画をテーマへ揃えます(TH-DK-2)。
       ダーク時は .ssg-theme-dark 側で dark に切替。:where のため利用側上書きが常に勝ちます。 */
    color-scheme: light;
    /* 色トークン */
    --ssg-accent: #3461c9;
    --ssg-accent-strong: #1d4ed8;
    --ssg-line: #f1f5f9;
    --ssg-line-strong: #e5e7eb;
    --ssg-divider: #d7dce3;
    --ssg-header-bg: #f8fafc;
    --ssg-row-hover-bg: #f1f5f9;
    --ssg-glyph: #94a3b8;
    --ssg-glyph-hover: #475569;
    --ssg-icon-hover-bg: #d6dee8;
    --ssg-icon-active-bg: #e3e9f5;
    --ssg-icon-active-bg-hover: #d4ddf0;
    --ssg-icon-active-border: #c7d3ea;
    /* 本体セル */
    --ssg-cell-bg: #ffffff;
    --ssg-cell-text: #0f172a;
    --ssg-readonly-bg: #f8fafc;
    --ssg-readonly-text: #64748b;
    --ssg-readonly-hover-bg: #eef2f7;
    /* ヘッダー */
    --ssg-header-text: #334155;
    --ssg-header-hover-bg: #e2e8f0;
    --ssg-select-bg: #e3e9f5;
    --ssg-select-bg-hover: #ccd7ee;
    /* 行選択(チェックボックス) */
    --ssg-row-selected-bg: #eff4ff;
    --ssg-checkbox-border: #94a3b8;
    --ssg-checkbox-bg: #ffffff;
    --ssg-checkbox-checked-bg: var(--ssg-accent);
    --ssg-checkbox-checked-mark: #ffffff;
    --ssg-checkbox-hover-border: var(--ssg-accent);
    /* オーバーレイ */
    --ssg-selection-fill: rgba(52, 97, 201, 0.08);
    /* 寸法トークン */
    --ssg-radius: 8px;
    --ssg-icon-btn-size: 20px;
    /* 寸法トークン(THEME-2): density プリセットの切替対象。standard は下記既定と同値。 */
    --ssg-cell-pad-x: 10px;
    --ssg-bar-pad-x: 10px;
    --ssg-bar-pad-y: 5px;
    /* ── 以下 TH-DK-1 追加: ポータル/パネル面・影・インク系のトークン化 ──
       ダーク対応(TH-DK-2)の前提。色味調整はこのブロックの値だけ変えれば全体に効きます。 */
    /* パネル面(popover / menu / filter popover / 管理系パネル共通) */
    --ssg-panel-bg: #ffffff;
    --ssg-panel-border: #cbd5e1;
    --ssg-panel-separator: #e2e8f0;
    /* パネル文字(強→弱の 6 段階) */
    --ssg-panel-text-strong: #1e293b;
    --ssg-panel-text: #334155;
    --ssg-panel-text-sub: #475569;
    --ssg-panel-text-muted: #64748b;
    --ssg-panel-text-faint: #94a3b8;
    --ssg-panel-text-disabled: #cbd5e1;
    /* パネル hover 面 */
    --ssg-panel-hover-bg: #f1f5f9;
    --ssg-panel-hover-bg-subtle: #f8fafc;
    /* パネルアクセント(意図的にグリッド accent #3461c9 より明るい系統) */
    --ssg-panel-accent: #2563eb;
    --ssg-panel-accent-bg: #eff6ff;
    --ssg-panel-accent-text: var(--ssg-accent-strong);
    --ssg-panel-accent-contrast: #ffffff;
    /* 危険操作(削除系 hover) */
    --ssg-danger: #dc2626;
    --ssg-danger-bg: #fef2f2;
    /* SegmentedControl(UP-1 / 統合ツールパネルのタブ切替。Mantine 風のトラック + 白インジケータ) */
    --ssg-seg-track-bg: #f1f3f5;
    --ssg-seg-indicator-bg: #ffffff;
    --ssg-seg-indicator-shadow: 0 1px 3px rgba(15, 23, 42, 0.18);
    /* 影(要素種別ごと) */
    --ssg-root-shadow: 0 4px 14px rgba(15, 23, 42, 0.04);
    --ssg-panel-shadow: 0 12px 28px rgba(15, 23, 42, 0.16);
    --ssg-popover-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
    --ssg-overlay-chip-shadow: 0 6px 20px rgba(15, 23, 42, 0.18);
    /* ピン留めペインの境界/影(SpreadsheetGrid.tsx の inline style から var() 参照) */
    --ssg-pane-border: #cbd5e1;
    --ssg-pane-shadow-left: 6px 0 8px -6px rgba(15, 23, 42, 0.35);
    --ssg-pane-shadow-right: -6px 0 8px -6px rgba(15, 23, 42, 0.35);
    /* インク系(暗色チップ): autosize pill / 列 D&D ゴースト(ghost は JS の inline style から
       var() 参照。トークン定義は本ブロックのセレクタリスト [data-grid-drag-ghost] で届きます) */
    --ssg-pill-bg: rgba(15, 23, 42, 0.82);
    --ssg-pill-text: #f8fafc;
    --ssg-pill-shadow: 0 6px 20px rgba(15, 23, 42, 0.25);
    --ssg-ghost-bg: #1e293b;
    --ssg-ghost-text: #f8fafc;
    --ssg-ghost-border: rgba(255, 255, 255, 0.10);
    --ssg-ghost-shadow: 0 8px 20px rgba(2, 6, 23, 0.34), 0 1px 2px rgba(2, 6, 23, 0.24);
    /* ツールチップ(TT-1。インク系 = ghost / pill と同系のダークチップ) */
    --ssg-tooltip-bg: #1e293b;
    --ssg-tooltip-text: #f8fafc;
    --ssg-tooltip-shadow: 0 4px 12px rgba(2, 6, 23, 0.25);
    /* その他 */
    --ssg-drop-indicator: #0f172a;
    --ssg-glyph-faint: #cbd5e1;
    --ssg-skeleton-bar: #e2e8f0;
  }

  /* 密度プリセット(THEME-2)。density prop が root へ付与する修飾子で寸法トークンを一括切替します。
     'standard' は修飾子なし(既定値のまま=従来と同値)。:where(特異度 0)なので、利用側のトークン
     上書き(特異度 (0,1,0) 以上)が常に勝ちます。rowHeight / headerHeight の既定値切替は JS 側
     (SpreadsheetGrid.tsx の DENSITY_DIMENSIONS)。チェックボックスは glyph 幾何が px 同期のため、
     ヘッダー文字サイズは autosize 定数(columnAutosize.ts の HEADER_FONT_SIZE)と同期のため固定です。
     popover / menu 等のポータルは .ssg-root 外のため対象外(必要なら後続バッチ)。 */
  :where(.ssg-root--density-compact) {
    --ssg-cell-pad-x: 6px;
    --ssg-bar-pad-x: 8px;
    --ssg-bar-pad-y: 3px;
    --ssg-icon-btn-size: 18px;
  }

  :where(.ssg-root--density-comfortable) {
    --ssg-cell-pad-x: 14px;
    --ssg-bar-pad-x: 12px;
    --ssg-bar-pad-y: 7px;
    --ssg-icon-btn-size: 22px;
  }

  /* セル文字サイズは既定で親から継承(利用側のフォント環境を尊重)のため、プリセットは相対値(em)で
     拡縮します(継承サイズ基準・standard は無指定=継承のまま)。autosize の実 DOM 計測ノードは
     .ssg-root 内へ append される .ssg-body-cell のため、この拡縮/padding トークンを自動で内包します。 */
  :where(.ssg-root--density-compact) .ssg-body-cell {
    font-size: 0.85em;
  }

  :where(.ssg-root--density-comfortable) .ssg-body-cell {
    font-size: 1.1em;
  }

  /* ── ダークテーマプリセット(TH-DK-2 / 案C: Mantine dark 系) ──
     theme='dark'(または 'auto' 解決)時に、グリッド root・全ポータル root(popover /
     menu / filter popover)・ドラッグゴースト・ツールチップへ .ssg-theme-dark が付与され、
     本ブロックが全色トークンを一括上書きします(:where 特異度 0 = 利用側の上書きが常に勝つ。
     既定ブロックより後方にあるため、クラス保持要素では dark 値が勝ちます)。
     パレットは Mantine の dark 階調(#1a1b1e / #25262b / #2c2e33 / #373a40)+ Mantine blue
     (#4dabf7 / #74c0fc)。色味調整はプレビュー HTML(dark-theme-preview.html)の JSON
     エディタで試してから本ブロックへ反映する運用を想定しています。
     寸法トークン(radius / padding / icon-btn-size)はテーマ対象外です。
     注記: --ssg-checkbox-checked-bg / --ssg-checkbox-hover-border / --ssg-panel-accent-text は
     既定が var() 参照(accent / accent-strong)のため、上書き不要で自動追従します。 */
  :where(.ssg-theme-dark) {
    color-scheme: dark;
    /* 色トークン */
    --ssg-accent: #4dabf7;
    --ssg-accent-strong: #74c0fc;
    --ssg-line: #212226;
    --ssg-line-strong: #2c2e33;
    --ssg-divider: #373a40;
    --ssg-header-bg: #25262b;
    --ssg-row-hover-bg: #25262b;
    --ssg-glyph: #909296;
    --ssg-glyph-hover: #c1c2c5;
    --ssg-glyph-faint: #5c5f66;
    --ssg-icon-hover-bg: #2c2e33;
    --ssg-icon-active-bg: #24344d;
    --ssg-icon-active-bg-hover: #2b3f5e;
    --ssg-icon-active-border: #3a5378;
    /* 本体セル */
    --ssg-cell-bg: #1a1b1e;
    --ssg-cell-text: #c1c2c5;
    --ssg-readonly-bg: #1f2023;
    --ssg-readonly-text: #909296;
    --ssg-readonly-hover-bg: #26272c;
    /* ヘッダー */
    --ssg-header-text: #c1c2c5;
    --ssg-header-hover-bg: #2c2e33;
    --ssg-select-bg: #24344d;
    --ssg-select-bg-hover: #2b3f5e;
    /* 行選択(チェックボックス) */
    --ssg-row-selected-bg: #1e2c44;
    --ssg-checkbox-border: #5c5f66;
    --ssg-checkbox-bg: #1a1b1e;
    --ssg-checkbox-checked-mark: #141517;
    /* オーバーレイ */
    --ssg-selection-fill: rgba(77, 171, 247, 0.13);
    /* パネル面 */
    --ssg-panel-bg: #25262b;
    --ssg-panel-border: #373a40;
    --ssg-panel-separator: #2c2e33;
    /* パネル文字 */
    --ssg-panel-text-strong: #f1f3f5;
    --ssg-panel-text: #c1c2c5;
    --ssg-panel-text-sub: #a6a7ab;
    --ssg-panel-text-muted: #909296;
    --ssg-panel-text-faint: #5c5f66;
    --ssg-panel-text-disabled: #43464d;
    /* パネル hover 面 */
    --ssg-panel-hover-bg: #2c2e33;
    --ssg-panel-hover-bg-subtle: #26272c;
    /* パネルアクセント */
    --ssg-panel-accent: #4dabf7;
    --ssg-panel-accent-bg: #1d3450;
    --ssg-panel-accent-contrast: #141517;
    /* 危険操作 */
    --ssg-danger: #ff6b6b;
    --ssg-danger-bg: #3a2325;
    /* SegmentedControl(トラックは面より一段沈め、インジケータは一段浮いた面) */
    --ssg-seg-track-bg: #1e1f23;
    --ssg-seg-indicator-bg: #373a40;
    --ssg-seg-indicator-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
    /* 影(ダークでは黒ベースで深めに) */
    --ssg-root-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
    --ssg-panel-shadow: 0 12px 28px rgba(0, 0, 0, 0.55);
    --ssg-popover-shadow: 0 10px 24px rgba(0, 0, 0, 0.5);
    --ssg-overlay-chip-shadow: 0 6px 20px rgba(0, 0, 0, 0.45);
    /* ピン留めペイン */
    --ssg-pane-border: #373a40;
    --ssg-pane-shadow-left: 6px 0 8px -6px rgba(0, 0, 0, 0.55);
    --ssg-pane-shadow-right: -6px 0 8px -6px rgba(0, 0, 0, 0.55);
    /* インク系(ダークでは一段浮いた明るめの面) */
    --ssg-pill-bg: rgba(55, 58, 64, 0.95);
    --ssg-pill-text: #f1f3f5;
    --ssg-pill-shadow: 0 6px 20px rgba(0, 0, 0, 0.45);
    --ssg-ghost-bg: #373a40;
    --ssg-ghost-text: #f1f3f5;
    --ssg-ghost-border: rgba(255, 255, 255, 0.12);
    --ssg-ghost-shadow: 0 8px 20px rgba(0, 0, 0, 0.5), 0 1px 2px rgba(0, 0, 0, 0.35);
    /* ツールチップ */
    --ssg-tooltip-bg: #373a40;
    --ssg-tooltip-text: #f1f3f5;
    --ssg-tooltip-shadow: 0 4px 12px rgba(0, 0, 0, 0.45);
    /* その他 */
    --ssg-drop-indicator: #c1c2c5;
    --ssg-skeleton-bar: #2c2e33;
  }

  /* box-sizing の自前正規化(THEME-1)。従来は一部要素が利用側グローバルリセットの有無で
     content-box / border-box が揺れ、素の環境と Tailwind 環境(preflight が全要素 border-box)で
     描画が食い違っていました。ルート/ポータル(popover / menu)配下を一律 border-box に固定して
     環境差を排除します。:where(特異度 0)なので、利用側が明示した box-sizing はそのまま勝ちます。
     注記: 擬似要素は :is()/:where() の引数に書けないため、::before / ::after は外側に付けます。 */
  :where(.ssg-root, .ssg-popover, .ssg-menu-panel, .ssg-filter-popover, .ssg-tooltip),
  :where(.ssg-root, .ssg-popover, .ssg-menu-panel, .ssg-filter-popover, .ssg-tooltip) :where(*),
  :where(.ssg-root, .ssg-popover, .ssg-menu-panel, .ssg-filter-popover, .ssg-tooltip) :where(*)::before,
  :where(.ssg-root, .ssg-popover, .ssg-menu-panel, .ssg-filter-popover, .ssg-tooltip) :where(*)::after {
    box-sizing: border-box;
  }

  /* 外枠 frame(top バー+本体+bottom バーを 1 枠に収める境界/角丸/影/クリップ)。 */
  .ssg-root {
    border: 1px solid var(--ssg-divider);
    border-radius: var(--ssg-radius);
    overflow: hidden;
    background-color: var(--ssg-cell-bg);
    box-shadow: var(--ssg-root-shadow);
  }

  /* ヘッダーのアイコンボタン(フィルター / メニュー) */
  .ssg-icon-btn {
    width: var(--ssg-icon-btn-size);
    height: var(--ssg-icon-btn-size);
    padding: 0;
    border: 1px solid transparent;
    border-radius: 6px;
    background-color: transparent;
    color: var(--ssg-glyph);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    cursor: pointer;
    font-size: 11px;
    line-height: 1;
    transition: background-color 100ms ease, color 100ms ease;
  }

  .ssg-icon-btn:hover {
    background-color: var(--ssg-icon-hover-bg);
    color: var(--ssg-glyph-hover);
  }

  .ssg-icon-btn--active {
    border-color: var(--ssg-icon-active-border);
    background-color: var(--ssg-icon-active-bg);
    color: var(--ssg-accent);
  }

  .ssg-icon-btn--active:hover {
    background-color: var(--ssg-icon-active-bg-hover);
    color: var(--ssg-accent);
  }

  /* 本体セル(データ行のセル)。座標 / 幅 / 高さ / zIndex はインライン(動的)。 */
  .ssg-body-cell {
    position: absolute;
    top: 0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    /* 変更(THEME-2): 横 padding をトークン化(密度プリセットの切替対象)。 */
    padding: 0 var(--ssg-cell-pad-x);
    border-right: 1px solid var(--ssg-line);
    border-bottom: 1px solid var(--ssg-line-strong);
    background-color: var(--ssg-cell-bg);
    color: var(--ssg-cell-text);
    white-space: nowrap;
    overflow: hidden;
    cursor: default;
    user-select: none;
    outline: none;
  }

  /* auto-height 駆動セル: 内容駆動高さ(下限はインライン min-height)で折り返し表示。 */
  .ssg-body-cell--autoheight {
    align-items: flex-start;
    white-space: normal;
    word-break: break-word;
    overflow: visible;
  }

  /* 追加(③): セル内容の水平寄せ(GridColumn.align)。基底に justify-content 未指定=左のため、
     center / right のときだけ上書きします(text-align は autoHeight 折り返し時の行揃え用)。 */
  .ssg-body-cell--align-center {
    justify-content: center;
    text-align: center;
  }

  .ssg-body-cell--align-right {
    justify-content: flex-end;
    text-align: right;
  }

  /* 行ホバー(hoveredRowIndex 由来。3 ペイン横断のため :hover では実装不可)。 */
  .ssg-body-cell--row-hovered {
    background-color: var(--ssg-row-hover-bg);
  }

  /* 読み取り専用セル(選択時は通常背景へ戻し、選択塗りを素直に見せる)。
     変更(THEME-3): 組み込みの淡色表示(背景 + 文字色)は dimReadOnlyCells prop
     (root の ssg-root--dim-readonly)による opt-in にしました(既定 false = 色変化なし)。
     .ssg-body-cell--readonly 自体は常時付与されるセマンティッククラスで、利用側 CSS の
     フックとして機能します。root 修飾子は :where(特異度 0)で包み、従来の特異度関係
     ((0,1,0) / hover 複合 (0,2,0))を維持します(利用側の連結上書きが従来どおり勝てる)。 */
  :where(.ssg-root--dim-readonly) .ssg-body-cell--readonly {
    background-color: var(--ssg-readonly-bg);
    color: var(--ssg-readonly-text);
  }

  :where(.ssg-root--dim-readonly) .ssg-body-cell--readonly.ssg-body-cell--row-hovered {
    background-color: var(--ssg-readonly-hover-bg);
  }

  /* ── ヘッダー ── */
  /* ヘッダー行コンテナ(sticky)。height はインライン。 */
  .ssg-header-row {
    position: sticky;
    top: 0;
    z-index: 6;
    background-color: var(--ssg-header-bg);
  }

  /* ヘッダーセル(列ヘッダー / 行ヘッダー / コーナー共通の土台)。座標 / 幅 / 高さはインライン。 */
  /* 変更(①②): padding 0 10px → 0 6px・gap 8px → 4px に圧縮し、ラベル領域を広げます。
     position:absolute は ssg-header-actions(hover オーバーレイ)の containing block を兼ねます。 */
  .ssg-header-cell {
    position: absolute;
    top: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    box-sizing: border-box;
    padding: 0 6px;
    border-right: 1px solid var(--ssg-line);
    border-bottom: 1px solid var(--ssg-divider);
    background-color: var(--ssg-header-bg);
    font-size: 13px;
    font-weight: 600;
    color: var(--ssg-header-text);
  }

  /* ヘッダーセルのホバー / 選択(列・行・全体で同色)。 */
  .ssg-header-cell--hovered {
    background-color: var(--ssg-header-hover-bg);
  }
  .ssg-header-cell--selected {
    background-color: var(--ssg-select-bg);
  }
  .ssg-header-cell--selected.ssg-header-cell--hovered {
    background-color: var(--ssg-select-bg-hover);
  }

  /* 行ヘッダー「#」セル(番号セル)。header-cell に重ねて中央寄せ + 細字。 */
  .ssg-row-header-cell {
    left: 0;
    z-index: 5;
    justify-content: center;
    font-weight: 500;
  }

  /* 左上コーナーセル。中央寄せ + 余白詰め + 右境界を濃く。 */
  .ssg-corner-cell {
    left: 0;
    z-index: 7;
    justify-content: center;
    padding: 0;
    border-right: 1px solid var(--ssg-line-strong);
    line-height: 1;
  }

  /* ── 行選択チェックボックス(CSS 描画・視覚専用。操作はガター/コーナーセル側)── */
  .ssg-row-checkbox {
    box-sizing: border-box;
    position: relative;
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--ssg-checkbox-border);
    border-radius: 4px;
    background-color: var(--ssg-checkbox-bg);
    transition:
      background-color 120ms ease,
      border-color 120ms ease;
  }
  /* チェック済み: accent 塗り + 白いチェックマーク(::after を回転ボーダーで描画)。 */
  .ssg-row-checkbox[data-state='checked'],
  .ssg-row-checkbox[data-state='indeterminate'] {
    border-color: var(--ssg-checkbox-checked-bg);
    background-color: var(--ssg-checkbox-checked-bg);
  }
  .ssg-row-checkbox[data-state='checked']::after {
    content: '';
    position: absolute;
    left: 4.5px;
    top: 1.5px;
    /* 変更(THEME-1): box-sizing 正規化(border-box)に伴う等価換算。旧 content-box の
       4×8 + 右下 2px ボーダー = ボーダー領域 6×10 を width/height で表現(描画は不変)。 */
    width: 6px;
    height: 10px;
    border: solid var(--ssg-checkbox-checked-mark);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  /* 一部選択(indeterminate): 白い横棒。 */
  .ssg-row-checkbox[data-state='indeterminate']::after {
    content: '';
    position: absolute;
    left: 3px;
    right: 3px;
    top: 6.5px;
    height: 2px;
    border-radius: 1px;
    background-color: var(--ssg-checkbox-checked-mark);
  }
  /* 未ロード(SSRM)等の無効表示。 */
  .ssg-row-checkbox[data-disabled='true'] {
    opacity: 0.45;
  }
  /* ガター/コーナーがチェックボックス表示のとき、ホバーで未選択枠を accent に。 */
  .ssg-row-header-cell--checkbox:hover .ssg-row-checkbox[data-state='unchecked'],
  .ssg-corner-cell--checkbox:hover .ssg-row-checkbox[data-state='unchecked'] {
    border-color: var(--ssg-checkbox-hover-border);
  }

  /* ── オーバーレイ / エディタ ── */
  /* アクティブセル枠。座標 / 幅 / 高さはインライン(動的)。枠色は accent に追従。 */
  .ssg-active-cell-overlay {
    box-sizing: border-box;
    border: 2px solid var(--ssg-accent);
    pointer-events: none;
    z-index: 4;
  }

  /* 選択範囲(枠 + 塗り)。 */
  .ssg-selection-overlay {
    box-sizing: border-box;
    border: 2px solid var(--ssg-accent);
    background-color: var(--ssg-selection-fill);
    pointer-events: none;
    z-index: 2;
  }

  /* セルエディタ。wrapper は座標のみインライン。 */
  .ssg-cell-editor {
    pointer-events: none;
    z-index: 5;
  }
  .ssg-cell-editor-input {
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    border: 2px solid var(--ssg-accent);
    outline: none;
    /* 変更(THEME-2): セル本体と同じ横 padding トークン(編集中も文字位置が揃う)。 */
    padding: 0 var(--ssg-cell-pad-x);
    margin: 0;
    font-size: 16px;
    color: var(--ssg-cell-text);
    background-color: var(--ssg-cell-bg);
    pointer-events: auto;
  }

  /* ── バー(ツールバー / ステータスバー) ── */
  /* 外枠。本体との境界は 1px divider のみ(top は下境界 / bottom は上境界)。 */
  .ssg-bar--top {
    border-bottom: 1px solid var(--ssg-divider);
  }
  .ssg-bar--bottom {
    border-top: 1px solid var(--ssg-divider);
  }

  .ssg-bar-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    /* 変更(THEME-2): padding をトークン化(密度プリセットの切替対象)。 */
    padding: var(--ssg-bar-pad-y) var(--ssg-bar-pad-x);
    background-color: var(--ssg-header-bg);
    flex-wrap: wrap;
  }

  .ssg-bar-group {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* 左側のタイトル + summary グループ(group に重ねる)。 */
  .ssg-bar-leading {
    min-width: 0;
    flex: 1 1 auto;
    color: var(--ssg-header-text);
    font-size: 12px;
  }

  /* 変更(シャープ化): 控えめな小見出し風(uppercase + 字間 + グレー)。スペースを取りすぎない。 */
  .ssg-bar-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ssg-glyph);
    margin-right: 2px;
  }

  /* 件数 chip。変更(シャープ化): pill(9999px) → 角丸 5px・箱なしのテキスト主体・等幅数字で
     必要最低限の表示にします。emphasis のみ薄い背景で強調します。 */
  .ssg-bar-chip {
    display: inline-flex;
    align-items: center;
    padding: 1px 6px;
    border-radius: 5px;
    background-color: transparent;
    border: none;
    color: var(--ssg-header-text);
    font-size: 11.5px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .ssg-bar-chip--emphasis {
    background-color: var(--ssg-header-hover-bg);
    color: var(--ssg-header-text);
    font-weight: 600;
  }
  /* 追加(FM-3): クリック可能 chip(既定トップバーの Filters chip → フィルター管理パネル開閉)。
     button 化しても span 時と同じ見た目になるよう font を継承し(button は font-family を
     継承しない)、hover でアクセント色に変えて操作可能であることを示す。 */
  .ssg-bar-chip--action {
    font-family: inherit;
    line-height: inherit;
    cursor: pointer;
  }
  .ssg-bar-chip--action:hover {
    background-color: var(--ssg-icon-active-bg);
    color: var(--ssg-accent-strong);
  }

  /* グローバルフィルター input + クリアボタン。変更(コンパクト化): 余白/フォントを圧縮。 */
  /* 変更(F-filter UI): 入力枠は .ssg-bar-input-group が担い、input 自身は枠なし・透明にします
     (左アイコン / 内側 × クリアと 1 つの枠に収めるため)。縦 padding のみ持ち、横は枠側 padding + gap。 */
  .ssg-bar-input {
    flex: 1 1 auto;
    min-width: 0;
    box-sizing: border-box;
    padding: 6px 0;
    border: none;
    outline: none;
    background-color: transparent;
    color: var(--ssg-cell-text);
    caret-color: var(--ssg-cell-text);
    font-size: 13px;
    line-height: 1.4;
    -webkit-text-fill-color: var(--ssg-cell-text);
  }

  /* 変更(F-filter UI): 枠(border / 背景 / 角丸 / フォーカスリング)をここへ移し、内側に
     [左アイコン][input][× クリア] を横並びで収めます。 */
  .ssg-bar-input-group {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
    max-width: 380px;
    box-sizing: border-box;
    padding: 0 8px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 6px;
    background-color: var(--ssg-cell-bg);
  }
  .ssg-bar-input-group:focus-within {
    border-color: var(--ssg-accent);
  }

  /* 追加(バー内訳): フィルター入力が単独(summary 非表示)のときは左寄せのまま少し広げます。 */
  .ssg-bar-container > .ssg-bar-input-group:only-child {
    max-width: 480px;
    flex: 1 1 auto;
  }

  /* 追加(F-filter UI): 入力枠 内側左の装飾アイコンです(SVG は currentColor を継承)。 */
  .ssg-bar-input-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ssg-glyph);
    pointer-events: none;
  }

  /* 追加(F-filter UI): 入力枠 内側右のクリア(×)ボタンです(枠なし・hover で淡い背景)。 */
  .ssg-bar-input-clear {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    padding: 0;
    border: none;
    border-radius: 4px;
    background-color: transparent;
    color: var(--ssg-glyph);
    cursor: pointer;
  }
  .ssg-bar-input-clear:hover {
    background-color: var(--ssg-row-hover-bg);
    color: var(--ssg-glyph-hover);
  }

  /* ── フィルターチップバー(GridFilterChipBar / FM-2) ── */
  /* showFilterChipBar(既定 false)の opt-in。トップバー直下・.ssg-root 内のためトークンが
     届く(padding は --ssg-bar-pad-* で density 連動)。有効フィルター 0 件時はコンポーネント
     側が null を返すため、空バーの領域は生じない。 */
  .ssg-filter-chip-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    padding: var(--ssg-bar-pad-y) var(--ssg-bar-pad-x);
    background-color: var(--ssg-header-bg);
    border-bottom: 1px solid var(--ssg-divider);
  }

  /* チップ本体。ネスト button 回避のため div コンテナ + 2 ボタン(ラベル / ×)構成。 */
  .ssg-filter-chip {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--ssg-icon-active-border);
    border-radius: 6px;
    background-color: var(--ssg-icon-active-bg);
    overflow: hidden;
  }
  .ssg-filter-chip--hidden {
    opacity: 0.75;
  }

  /* ラベルボタン(列名 + 要約)。クリックで対象列へジャンプ + popover(パネルの ✎ と同経路)。 */
  .ssg-filter-chip-label {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    max-width: 260px;
    padding: 2px 6px 2px 8px;
    border: none;
    background-color: transparent;
    color: var(--ssg-accent-strong);
    font-size: 11.5px;
    line-height: 1.5;
    cursor: pointer;
  }
  .ssg-filter-chip-label:disabled {
    cursor: default;
  }
  .ssg-filter-chip-label:not(:disabled):hover {
    background-color: var(--ssg-icon-active-bg-hover);
  }
  .ssg-filter-chip-name {
    font-weight: 700;
    white-space: nowrap;
  }
  .ssg-filter-chip-summary {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* × ボタン(この列のフィルターをクリア)。 */
  .ssg-filter-chip-clear {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    align-self: stretch;
    border: none;
    background-color: transparent;
    color: var(--ssg-accent-strong);
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
  }
  .ssg-filter-chip-clear:disabled {
    cursor: default;
    color: var(--ssg-glyph);
  }
  .ssg-filter-chip-clear:not(:disabled):hover {
    background-color: var(--ssg-icon-active-bg-hover);
  }

  /* すべてクリア(列フィルターのみ対象 = フィルター管理パネルと同じ切り分け)。 */
  .ssg-filter-chip-bar-clear-all {
    border: none;
    background-color: transparent;
    color: var(--ssg-glyph-hover);
    font-size: 11.5px;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .ssg-filter-chip-bar-clear-all:disabled {
    color: var(--ssg-glyph);
    cursor: default;
  }
  .ssg-filter-chip-bar-clear-all:not(:disabled):hover {
    background-color: var(--ssg-header-hover-bg);
  }

  /* ── ポップオーバー/パネル共通 ── */
  /* ポータルで body 直下に出るため .ssg-root からの継承は届かないが、TH-DK-1 でトークン定義
     セレクタリストに各ポータル root を加えたため、以降は --ssg-panel-* トークンで参照する。
     パネルアクセント(--ssg-panel-accent)は意図的にグリッド accent より明るい系統。 */
  .ssg-popover {
    position: fixed;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    padding: 12px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 12px;
    background-color: var(--ssg-panel-bg);
    box-shadow: var(--ssg-panel-shadow);
    z-index: 1000;
  }

  .ssg-popover-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding-bottom: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--ssg-panel-separator);
  }

  .ssg-popover-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--ssg-panel-text-strong);
    user-select: none;
  }

  .ssg-popover-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 6px;
    background-color: transparent;
    color: var(--ssg-panel-text-muted);
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }
  .ssg-popover-close:hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  .ssg-popover-footer {
    padding-top: 8px;
    margin-top: 8px;
    border-top: 1px solid var(--ssg-panel-separator);
    display: flex;
    gap: 8px;
  }

  /* 追加(FM-4): ドラッグ可能パネルのヘッダー(掴み領域)。ドラッグ中の位置 clamp・保持は
     controller 側(panelDragGeometry)が担う。touch-action: none はタッチでの pointermove を
     スクロールに取られないための指定。
     変更(UP-1): 使用箇所は統合ツールパネル(ToolPanel)のヘッダー 1 箇所になった。 */
  .ssg-popover-header--draggable {
    cursor: grab;
    touch-action: none;
  }
  .ssg-popover-header--draggable:active {
    cursor: grabbing;
  }

  /* ── 統合ツールパネル(UP-1 / ToolPanel) ── */
  /* フレームは .ssg-popover(radius 12 / padding 12 / flex column)。フィルター管理 /
     列の表示 / 並び替えのコンテンツを SegmentedControl で切り替える。全体は max-height で
     キャップし、各コンテンツのリスト(flex: 1 / overflow-y: auto)がスクロールを担う
     (旧 3 パネルの max-height: 420px を継承)。 */
  .ssg-toolpanel {
    max-height: 420px;
  }

  /* 追加(UP-2 / 既開時フラッシュ): 既に開いているパネルへ再度 open(導線の再クリック /
     別タブ切替)したとき、パネルがどこに出ているかを一瞬示すフラッシュ。クラス
     (--flash)は JS(ToolPanel の flashTick effect)が直付けし animationend で除去する
     一過性演出(ヘッダージャンプ ssg-header-cell--jump-flash と同方式)。accent リングを
     出して通常影へ戻す。prefers-reduced-motion では抑制する。 */
  @keyframes ssg-toolpanel-flash {
    0% {
      box-shadow:
        0 0 0 3px var(--ssg-panel-accent-bg),
        0 0 0 4px var(--ssg-panel-accent),
        var(--ssg-panel-shadow);
    }
    100% {
      box-shadow: var(--ssg-panel-shadow);
    }
  }
  .ssg-toolpanel--flash {
    animation: ssg-toolpanel-flash 0.45s ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    .ssg-toolpanel--flash {
      animation: none;
    }
  }

  /* ヘッダー(SegmentedControl + ×)。--draggable(FM-4)併用で掴んで移動できる。 */
  .ssg-toolpanel-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--ssg-panel-separator);
  }

  /* SegmentedControl(Mantine 風)。セグメントは等幅で、インジケータは CSS 変数
     (--ssg-seg-count / --ssg-seg-index。ToolPanel が inline style で与える)駆動の
     translateX だけで追従する(実測不要 = resize / タブ数変化に自動追従)。 */
  .ssg-toolpanel-seg {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    min-width: 0;
    padding: 3px;
    border-radius: 9px;
    background-color: var(--ssg-seg-track-bg);
  }
  .ssg-toolpanel-seg-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: calc((100% - 6px) / var(--ssg-seg-count));
    border-radius: 7px;
    background-color: var(--ssg-seg-indicator-bg);
    box-shadow: var(--ssg-seg-indicator-shadow);
    transform: translateX(calc(var(--ssg-seg-index) * 100%));
    transition: transform 160ms ease;
  }
  .ssg-toolpanel-seg-btn {
    position: relative;
    z-index: 1;
    flex: 1 1 0;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 4px 6px;
    border: none;
    border-radius: 7px;
    background: transparent;
    color: var(--ssg-panel-text-muted);
    font-size: 12.5px;
    font-weight: 500;
    line-height: 1.3;
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 120ms ease;
  }
  .ssg-toolpanel-seg-btn:not(.ssg-toolpanel-seg-btn--active):hover {
    color: var(--ssg-panel-text-sub);
  }
  .ssg-toolpanel-seg-btn--active {
    color: var(--ssg-panel-text-strong);
    font-weight: 600;
    cursor: default;
  }

  /* 件数バッジ(適用中フィルター数 / ソート基準数)。0 件は view 側で非描画。 */
  .ssg-toolpanel-seg-badge {
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 8px;
    background-color: var(--ssg-panel-accent);
    color: var(--ssg-panel-accent-contrast);
    font-size: 10px;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
  }

  /* ボディ(アクティブタブのコンテンツ)。自然高 + min-height 方式: タブごとの内容高で
     伸縮しつつ min-height で切替時のガタつきを抑える。内容が短いタブでは各コンテンツの
     リスト(flex: 1)が伸びてフッターが下端に揃う。frame の max-height(420)に達したら
     flex 連鎖(flex: 1 1 auto / リストの min-height: 0)でリスト側がスクロールする。 */
  .ssg-toolpanel-body {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 240px;
    min-width: 0;
  }

  /* ── 並び替えタブのコンテンツ(SortManagementPanel) ── */
  /* 変更(UP-1): 旧 .ssg-sort-panel(独立フレーム)は統合ツールパネルへ集約し撤去。 */
  .ssg-sort-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    margin: 0 -4px;
    padding: 0 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ssg-sort-empty {
    font-size: 12px;
    color: var(--ssg-panel-text-faint);
    padding: 10px 4px;
    user-select: none;
  }

  /* レベル行。ドロップ前線インジケータ / ドラッグ中は修飾子で表現。 */
  .ssg-sort-level {
    display: flex;
    align-items: center;
    gap: 6px;
    border-top: 2px solid transparent;
    opacity: 1;
  }
  .ssg-sort-level--drop-before {
    border-top-color: var(--ssg-panel-accent);
  }
  .ssg-sort-level--dragging {
    opacity: 0.4;
  }

  /* ⠿ ドラッグハンドル。hover 背景は draggable(=未 disabled)のときのみ。 */
  .ssg-sort-handle {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 16px;
    height: 26px;
    border-radius: 6px;
    cursor: grab;
    touch-action: none;
  }
  .ssg-sort-handle--dragging {
    cursor: grabbing;
  }
  .ssg-sort-handle--disabled {
    cursor: default;
  }
  .ssg-sort-handle:not(.ssg-sort-handle--disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  .ssg-sort-badge {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 9px;
    background-color: var(--ssg-panel-accent-bg);
    color: var(--ssg-panel-accent);
    font-size: 11px;
    font-weight: 700;
    user-select: none;
  }

  .ssg-sort-select {
    flex: 1;
    min-width: 0;
    box-sizing: border-box;
    padding: 5px 6px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 6px;
    font-size: 13px;
    color: var(--ssg-panel-text);
    background-color: var(--ssg-panel-bg);
    cursor: pointer;
  }
  .ssg-sort-select:disabled {
    cursor: default;
  }

  /* 方向セグメント(昇順 / 降順)。active は青で塗り、disabled はグレー文字。 */
  .ssg-sort-dir-group {
    flex: 0 0 auto;
    display: flex;
  }
  .ssg-sort-dir-btn {
    flex: 0 0 auto;
    box-sizing: border-box;
    padding: 4px 9px;
    border: 1px solid var(--ssg-panel-border);
    background-color: var(--ssg-panel-bg);
    color: var(--ssg-panel-text-sub);
    font-size: 12px;
    line-height: 1.4;
    cursor: pointer;
  }
  .ssg-sort-dir-group > .ssg-sort-dir-btn:first-child {
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
    border-right: none;
  }
  .ssg-sort-dir-group > .ssg-sort-dir-btn:last-child {
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
  }
  .ssg-sort-dir-btn--active {
    border-color: var(--ssg-panel-accent);
    background-color: var(--ssg-panel-accent);
    color: var(--ssg-panel-accent-contrast);
  }
  .ssg-sort-dir-btn:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }

  .ssg-sort-delete {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border: none;
    border-radius: 6px;
    background-color: transparent;
    color: var(--ssg-panel-text-muted);
    cursor: pointer;
    font-size: 15px;
    line-height: 1;
  }
  .ssg-sort-delete:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }
  .ssg-sort-delete:not(:disabled):hover {
    background-color: var(--ssg-danger-bg);
    color: var(--ssg-danger);
  }

  .ssg-sort-drop-end {
    height: 0;
    border-top: 2px solid var(--ssg-panel-accent);
  }

  /* フッターボタン(基準を追加 / すべてクリア)。 */
  .ssg-sort-footer-btn {
    box-sizing: border-box;
    border: 1px solid var(--ssg-panel-separator);
    border-radius: 8px;
    background-color: transparent;
    color: var(--ssg-panel-text);
    cursor: pointer;
    font-size: 13px;
    text-align: center;
    user-select: none;
  }
  .ssg-sort-footer-btn--add {
    flex: 1;
    padding: 7px 8px;
  }
  .ssg-sort-footer-btn--clear {
    flex: 0 0 auto;
    padding: 7px 12px;
  }
  .ssg-sort-footer-btn:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }
  .ssg-sort-footer-btn:not(:disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  .ssg-sort-note {
    font-size: 11px;
    color: var(--ssg-panel-text-faint);
    margin-top: 8px;
    user-select: none;
  }

  /* ── フィルタータブのコンテンツ(FilterManagementPanel / FM-1) ── */
  /* 変更(UP-1): 旧 .ssg-filter-manage-panel(独立フレーム)は統合ツールパネルへ集約し撤去。 */
  .ssg-filter-manage-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    margin: 0 -4px;
    padding: 0 4px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ssg-filter-manage-empty {
    font-size: 12px;
    color: var(--ssg-panel-text-faint);
    padding: 10px 4px;
    user-select: none;
  }

  /* 一覧行。hover で淡背景(✎ / × の操作対象を示す)。 */
  .ssg-filter-manage-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 6px;
    border-radius: 8px;
  }
  .ssg-filter-manage-row:hover {
    background-color: var(--ssg-panel-hover-bg-subtle);
  }
  /* グローバルフィルター行。一覧(列フィルター)との区切りを持ち、hover 強調はしません。 */
  .ssg-filter-manage-row--global {
    border-bottom: 1px solid var(--ssg-panel-separator);
    border-radius: 0;
    margin-bottom: 6px;
    padding-bottom: 9px;
  }
  .ssg-filter-manage-row--global:hover {
    background-color: transparent;
  }

  /* 左端グリフ(漏斗 / 虫めがね)。漏斗はヘッダーのフィルター適用中マークと同アクセント。 */
  .ssg-filter-manage-glyph {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    color: var(--ssg-panel-accent-text);
  }
  .ssg-filter-manage-glyph--global {
    color: var(--ssg-panel-text-muted);
  }

  /* 列名(上段)+ 要約(下段)。どちらも 1 行 ellipsis(はみ出しは title 属性で補完)。 */
  .ssg-filter-manage-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .ssg-filter-manage-name {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--ssg-panel-text-strong);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ssg-filter-manage-hidden-note {
    margin-left: 4px;
    font-size: 10.5px;
    font-weight: 500;
    color: var(--ssg-panel-text-faint);
  }
  .ssg-filter-manage-summary {
    font-size: 11.5px;
    color: var(--ssg-panel-text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* 行内アクション(✎ / ×)。--danger は hover で赤系(列メニューの危険操作と同系色)。 */
  .ssg-filter-manage-actions {
    display: flex;
    gap: 2px;
    flex: 0 0 auto;
  }
  .ssg-filter-manage-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 6px;
    background-color: transparent;
    color: var(--ssg-panel-text-muted);
    cursor: pointer;
    font-size: 13px;
    line-height: 1;
  }
  .ssg-filter-manage-icon-btn:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }
  .ssg-filter-manage-icon-btn:not(:disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
    color: var(--ssg-panel-text-strong);
  }
  .ssg-filter-manage-icon-btn--danger:not(:disabled):hover {
    background-color: var(--ssg-danger-bg);
    color: var(--ssg-danger);
  }

  /* フッター: 追加セレクト + すべてクリア。 */
  .ssg-filter-manage-add {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    padding: 5px 6px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 6px;
    background-color: var(--ssg-panel-bg);
    color: var(--ssg-panel-text);
    cursor: pointer;
    outline: none;
  }
  .ssg-filter-manage-add:focus {
    border-color: var(--ssg-panel-accent);
  }
  .ssg-filter-manage-add:disabled {
    color: var(--ssg-panel-text-faint);
    cursor: default;
  }
  .ssg-filter-manage-clear-all {
    flex: 0 0 auto;
    border: none;
    background-color: transparent;
    color: var(--ssg-panel-text-muted);
    font-size: 12px;
    cursor: pointer;
    padding: 5px 8px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .ssg-filter-manage-clear-all:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }
  .ssg-filter-manage-clear-all:not(:disabled):hover {
    background-color: var(--ssg-danger-bg);
    color: var(--ssg-danger);
  }

  /* ── 列タブのコンテンツ(ColumnChooserPanel) ── */
  /* 変更(UP-1): 旧 .ssg-chooser-panel(独立フレーム)は統合ツールパネルへ集約し撤去。 */
  .ssg-chooser-search-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  /* 全選択チェックボックスのボタン枠。 */
  .ssg-chooser-master-btn {
    display: flex;
    align-items: center;
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }
  .ssg-chooser-master-btn:disabled {
    cursor: default;
  }

  .ssg-chooser-search-field {
    position: relative;
    flex: 1;
    min-width: 0;
  }
  .ssg-chooser-search-icon {
    position: absolute;
    left: 9px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ssg-panel-text-faint);
    font-size: 13px;
    line-height: 1;
    pointer-events: none;
  }
  .ssg-chooser-search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 7px 10px 7px 26px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 8px;
    font-size: 13px;
    color: var(--ssg-panel-text);
    outline: none;
  }

  /* 列一覧(スクロール)。セクション側でレイアウトするため flex は付けない。 */
  .ssg-chooser-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    margin: 0 -4px;
    padding: 0 4px;
  }

  .ssg-chooser-empty {
    font-size: 12px;
    color: var(--ssg-panel-text-faint);
    padding: 10px 4px;
    user-select: none;
  }

  .ssg-chooser-section-heading {
    font-size: 11px;
    font-weight: 700;
    color: var(--ssg-panel-text-faint);
    letter-spacing: 0.4px;
    padding: 8px 4px 4px;
    user-select: none;
  }

  /* 列行。ドロップ前線 / ドラッグ中は修飾子で。 */
  .ssg-chooser-row {
    display: flex;
    align-items: center;
    gap: 4px;
    border-top: 2px solid transparent;
    opacity: 1;
  }
  .ssg-chooser-row--drop-before {
    border-top-color: var(--ssg-panel-accent);
  }
  .ssg-chooser-row--dragging {
    opacity: 0.4;
  }

  /* ⠿ ドラッグハンドル。hover は draggable のときのみ。 */
  .ssg-chooser-handle {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 18px;
    height: 28px;
    border-radius: 6px;
    cursor: grab;
    touch-action: none;
  }
  .ssg-chooser-handle--dragging {
    cursor: grabbing;
  }
  .ssg-chooser-handle--disabled {
    cursor: default;
  }
  .ssg-chooser-handle:not(.ssg-chooser-handle--disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  /* 表示/非表示トグル(チェックボックス + ラベル)。 */
  .ssg-chooser-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
    box-sizing: border-box;
    padding: 7px 8px;
    border: none;
    border-radius: 8px;
    background-color: transparent;
    cursor: pointer;
    text-align: left;
  }
  .ssg-chooser-toggle:disabled {
    cursor: default;
  }
  .ssg-chooser-toggle:not(:disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  .ssg-chooser-label {
    min-width: 0;
    flex: 1;
    font-size: 13px;
    color: var(--ssg-panel-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ssg-chooser-label--muted {
    color: var(--ssg-panel-text-faint);
  }

  .ssg-chooser-drop-end {
    height: 0;
    border-top: 2px solid var(--ssg-panel-accent);
  }

  /* フッター(リセットボタン + 注記)。sort と異なり縦積み。 */
  .ssg-chooser-footer {
    padding-top: 8px;
    margin-top: 8px;
    border-top: 1px solid var(--ssg-panel-separator);
  }
  .ssg-chooser-reset-btn {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 7px 8px;
    border: 1px solid var(--ssg-panel-separator);
    border-radius: 8px;
    background-color: transparent;
    color: var(--ssg-panel-text);
    cursor: pointer;
    font-size: 13px;
    text-align: center;
    user-select: none;
  }
  .ssg-chooser-reset-btn:disabled {
    color: var(--ssg-panel-text-disabled);
    cursor: default;
  }
  .ssg-chooser-reset-btn:not(:disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  .ssg-chooser-note {
    font-size: 11px;
    color: var(--ssg-panel-text-faint);
    margin-top: 8px;
    user-select: none;
  }

  /* ── 3状態チェックボックス(CheckBox) ── */
  .ssg-checkbox {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    border-radius: 5px;
    border: 1.5px solid var(--ssg-checkbox-border);
    background-color: var(--ssg-panel-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 80ms ease, border-color 80ms ease;
  }
  .ssg-checkbox--filled {
    border-color: var(--ssg-panel-accent);
    background-color: var(--ssg-panel-accent);
  }
  .ssg-checkbox--disabled {
    border-color: var(--ssg-panel-border);
    background-color: var(--ssg-panel-hover-bg);
  }
  .ssg-checkbox-dash {
    width: 9px;
    height: 2px;
    border-radius: 1px;
    background-color: var(--ssg-panel-accent-contrast);
  }

  /* ── 列フィルター popover(ColumnFilterPopover) ── */
  /* パネル(.ssg-popover)とは別の軽量フレーム(radius 10 / 影も控えめ)。 */
  .ssg-filter-popover {
    position: fixed;
    box-sizing: border-box;
    padding: 12px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 10px;
    background-color: var(--ssg-panel-bg);
    box-shadow: var(--ssg-popover-shadow);
    z-index: 1000;
  }

  .ssg-filter-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--ssg-panel-text);
    margin-bottom: 8px;
  }

  /* 種別ヒント / メタ情報行。--ellipsis は省略表示を足す。 */
  .ssg-filter-hint {
    font-size: 11px;
    color: var(--ssg-panel-text-muted);
    margin-bottom: 8px;
  }
  .ssg-filter-meta {
    font-size: 11px;
    color: var(--ssg-panel-text-muted);
    margin-bottom: 10px;
  }
  .ssg-filter-meta--ellipsis {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ssg-filter-collecting {
    padding: 24px;
    text-align: center;
    font-size: 12px;
    color: var(--ssg-panel-text-muted);
  }

  /* テキスト/数値入力 + select。 */
  .ssg-filter-input {
    width: 100%;
    box-sizing: border-box;
    padding: 8px 10px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 8px;
    outline: none;
    margin-bottom: 8px;
  }
  .ssg-filter-select {
    width: 100%;
    box-sizing: border-box;
    padding: 8px 10px;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 8px;
    outline: none;
    margin-bottom: 8px;
    background-color: var(--ssg-panel-bg);
  }

  /* set フィルター: 全選択行 / 候補リスト / 行 / 件数。 */
  .ssg-filter-selectall {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 28px;
    padding: 0 8px;
    cursor: pointer;
    font-size: 12px;
    color: var(--ssg-panel-text);
    border-bottom: 1px solid var(--ssg-panel-separator);
    user-select: none;
  }
  .ssg-filter-selectall-label {
    font-weight: 600;
  }
  .ssg-filter-list {
    height: 208px;
    overflow-y: auto;
    border: 1px solid var(--ssg-panel-separator);
    border-top: none;
    border-radius: 0 0 8px 8px;
    margin-bottom: 8px;
  }
  .ssg-filter-empty {
    padding: 12px;
    font-size: 12px;
    color: var(--ssg-panel-text-faint);
    text-align: center;
  }
  /* 仮想化スペーサ。高さ(getTotalSize)は inline で与える。 */
  .ssg-filter-virt {
    position: relative;
    width: 100%;
  }
  /* 候補行。transform(translateY) と height は virtualItem を inline で与える。 */
  .ssg-filter-option {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 8px;
    box-sizing: border-box;
    cursor: pointer;
    font-size: 12px;
    color: var(--ssg-panel-text);
    user-select: none;
  }
  .ssg-filter-option-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* フッター(クリア / 適用・閉じる)。 */
  .ssg-filter-footer {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  .ssg-filter-btn-secondary {
    border: 1px solid var(--ssg-panel-border);
    background-color: var(--ssg-panel-bg);
    color: var(--ssg-panel-text-sub);
    border-radius: 8px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 12px;
  }
  .ssg-filter-btn-primary {
    border: 1px solid var(--ssg-panel-accent);
    background-color: var(--ssg-panel-accent);
    color: var(--ssg-panel-accent-contrast);
    border-radius: 8px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 12px;
  }

  /* ── 列メニュー popover(ColumnMenuPopover) ── */
  /* ルート/サブメニュー共通のパネル枠(radius 10)。座標/zIndex は inline。 */
  .ssg-menu-panel {
    padding: 8px;
    box-sizing: border-box;
    border: 1px solid var(--ssg-panel-border);
    border-radius: 10px;
    background-color: var(--ssg-panel-bg);
    box-shadow: var(--ssg-popover-shadow);
  }

  .ssg-menu-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--ssg-panel-text);
    padding: 2px 8px 6px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    border-bottom: 1px solid var(--ssg-panel-separator);
    margin-bottom: 4px;
    user-select: none;
  }

  /* メニュー項目。disabled(属性) / --disabled(aria 相当)で淡色、hover で淡背景、
     --active(サブメニュー開)で淡背景を維持。 */
  .ssg-menu-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    box-sizing: border-box;
    padding: 7px 8px;
    border: none;
    border-radius: 8px;
    background-color: transparent;
    color: var(--ssg-panel-text);
    font-size: 13px;
    text-align: left;
    cursor: pointer;
  }
  .ssg-menu-item:disabled,
  .ssg-menu-item--disabled {
    color: var(--ssg-panel-text-faint);
    cursor: default;
  }
  .ssg-menu-item--active {
    background-color: var(--ssg-panel-hover-bg);
  }
  .ssg-menu-item:not(:disabled):not(.ssg-menu-item--disabled):hover {
    background-color: var(--ssg-panel-hover-bg);
  }

  /* 追加(バッチ②/語彙拡張): セクション見出し(Mantine Menu.Label 相当)。非インタラクティブ。 */
  .ssg-menu-section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--ssg-panel-text-faint);
    padding: 6px 8px 2px;
    user-select: none;
  }

  /* 追加(バッチ②/語彙拡張): 危険操作(削除等)の赤系強調(Mantine color="red" 相当)。
     base の color / hover と同 specificity のため、後勝ちで上書きされるようここに置きます。 */
  .ssg-menu-item--danger {
    color: var(--ssg-danger);
  }
  .ssg-menu-item--danger:not(:disabled):not(.ssg-menu-item--disabled):hover {
    background-color: var(--ssg-danger-bg);
  }

  .ssg-menu-submenu-anchor {
    position: relative;
  }

  /* 左端 ✓ 列スペーサ / ソート方向アイコン / 固定 ✓ / ラベル / › キャレット。 */
  .ssg-menu-icon {
    width: 14px;
    flex: 0 0 auto;
    text-align: center;
  }
  .ssg-menu-sort-icon {
    width: 14px;
    flex: 0 0 auto;
    text-align: center;
    color: var(--ssg-panel-text-faint);
    font-weight: 400;
  }
  .ssg-menu-sort-icon--active {
    color: var(--ssg-panel-accent);
    font-weight: 700;
  }
  .ssg-menu-check {
    width: 14px;
    flex: 0 0 auto;
    text-align: center;
    color: var(--ssg-panel-accent);
    font-weight: 700;
  }
  .ssg-menu-check--hidden {
    visibility: hidden;
  }
  .ssg-menu-label {
    min-width: 0;
    flex: 1;
  }
  .ssg-menu-label--sorted {
    color: var(--ssg-panel-accent-text);
  }
  .ssg-menu-caret {
    flex: 0 0 auto;
    color: var(--ssg-panel-text-faint);
    font-size: 12px;
    line-height: 1;
  }

  .ssg-menu-separator {
    border-top: 1px solid var(--ssg-panel-separator);
    margin: 4px 0;
  }
  .ssg-menu-note {
    font-size: 11px;
    color: var(--ssg-panel-text-faint);
    padding: 4px 8px 2px;
    user-select: none;
  }

  /* フッター(閉じる)。 */
  .ssg-menu-footer {
    border-top: 1px solid var(--ssg-panel-separator);
    margin-top: 4px;
    padding-top: 6px;
    display: flex;
    justify-content: flex-end;
  }
  .ssg-menu-close-btn {
    border: 1px solid var(--ssg-panel-border);
    background-color: var(--ssg-panel-bg);
    color: var(--ssg-panel-text-sub);
    border-radius: 8px;
    padding: 5px 10px;
    cursor: pointer;
    font-size: 12px;
  }

  /* ── ボディ行コンテナ(GridBodyLayer)。height/transform は inline。 ── */
  .ssg-body-row {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    contain: layout style paint;
  }

  /* 追加(行選択): チェック選択された行のハイライト。行 div に背景を敷き、非ホバーの
     本体セルを透過にして下地(選択色)を見せます(ホバーセルはホバー色を優先)。
     行ヘッダ(ガター)セルは対象外なので番号/チェック欄の色はそのまま保ちます。 */
  .ssg-body-row--checked {
    background-color: var(--ssg-row-selected-bg);
  }
  .ssg-body-row--checked .ssg-body-cell:not(.ssg-body-cell--row-hovered) {
    background-color: transparent;
  }

  /* ── ヘッダー内要素(GridHeaderRow) ── */
  /* 列並べ替え grip。 */
  .ssg-header-grip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 12px;
    height: 20px;
    flex: 0 0 auto;
    color: var(--ssg-glyph-faint);
    cursor: grab;
    touch-action: none;
    user-select: none;
  }
  /* 追加(②): フィルター適用中の漏斗・ソート矢印など「状態」を常時表示する右寄せスロット。
     hover で出る操作群(ssg-header-actions)とは別系統で、非hover でも見えます。 */
  .ssg-header-status {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    flex: 0 0 auto;
  }
  /* 追加(②): grip + 列メニュー(⋮)を載せる hover オーバーレイ。非hover は opacity:0 で
     幅を取らず(absolute)、ラベルが全幅使えます。hover でフェードインし、不透明背景で
     ラベル末尾を覆います。タッチ端末(hover 不可)は @media で常時表示の通常フローへ戻します。 */
  .ssg-header-actions {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0 6px 0 14px;
    background-color: var(--ssg-header-bg);
    opacity: 0;
    transition: opacity 100ms ease;
    pointer-events: none;
  }
  .ssg-header-cell:hover .ssg-header-actions {
    opacity: 1;
    pointer-events: auto;
    background-color: var(--ssg-header-hover-bg);
  }
  @media (hover: none) {
    .ssg-header-actions {
      position: static;
      height: auto;
      padding: 0;
      background-color: transparent;
      opacity: 1;
      pointer-events: auto;
    }
  }
  /* 追加: hover で出る操作アイコン(grip / ⋮)の通常色を濃く(slate-600)して視認性を上げます。
     メニュー表示中の ⋮ のアクセント色(--active)は :not(--active) で除外し、従来どおり優先します。 */
  .ssg-header-actions .ssg-header-grip,
  .ssg-header-actions .ssg-icon-btn:not(.ssg-icon-btn--active) {
    color: var(--ssg-glyph-hover);
  }
  /* ヘッダーテキスト。フィルター適用中はアクセント色。 */
  .ssg-header-label {
    min-width: 0;
    flex: 1;
    color: var(--ssg-header-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ssg-header-label--filtered {
    color: var(--ssg-accent-strong);
  }
  /* ソート方向の受動表示(矢印 + 優先番号)。 */
  .ssg-header-sort {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    flex: 0 0 auto;
    color: var(--ssg-accent);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }
  .ssg-header-sort-priority {
    font-size: 9px;
    font-weight: 700;
    line-height: 1;
  }
  /* 追加(②③): フィルター適用中マーク(小さな漏斗)。状態表示のみで非クリック。色はアクセント。
     フィルターの操作自体は列メニュー(⋮)の「フィルター」へ集約しています。 */
  .ssg-header-filtered-mark {
    display: inline-flex;
    align-items: center;
    color: var(--ssg-accent-strong);
    flex: 0 0 auto;
  }
  /* 追加(FM-1): フィルター管理パネルからのジャンプ先ヘッダーを一瞬強調するフラッシュです。
     クラス(--jump-flash)は JS が直付けし animationend で除去します(状態を持たない一過性の
     視認補助。React はヘッダーセルの className prop が変化したときだけ属性を書き戻すため、
     直付けクラスは通常アニメ完了まで残ります)。トークン参照のため .ssg-root 内専用です。 */
  @keyframes ssg-header-jump-flash {
    0% {
      box-shadow: inset 0 0 0 2px var(--ssg-accent);
      background-color: var(--ssg-select-bg);
    }
    70% {
      box-shadow: inset 0 0 0 2px var(--ssg-accent);
      background-color: var(--ssg-select-bg);
    }
    100% {
      box-shadow: none;
    }
  }
  .ssg-header-cell--jump-flash {
    animation: ssg-header-jump-flash 1.2s ease-out;
  }
  /* 列リサイズ把手。 */
  .ssg-header-resize {
    position: absolute;
    top: 0;
    right: -3px;
    width: 6px;
    height: 100%;
    cursor: col-resize;
    z-index: 3;
  }

  /* ── スケルトン(GridBodyLayer 読み込み中) ── */
  .ssg-skeleton-rowheader {
    color: var(--ssg-glyph);
  }
  /* バーの幅は inline(barWidth)で与える。 */
  .ssg-skeleton-bar {
    height: 10px;
    border-radius: 4px;
    background-color: var(--ssg-skeleton-bar);
  }

  /* ── グリッド本体シェル / スクロール(SpreadsheetGrid) ── */
  /* cursor(計測中 progress)のみ inline。 */
  .ssg-shell {
    position: relative;
    overflow: hidden;
    background-color: var(--ssg-cell-bg);
  }
  .ssg-scroll-container {
    max-height: 480px;
    overflow: auto;
    position: relative;
  }
  /* width/min-width/height(スクロール範囲)は inline。 */
  .ssg-inner-row {
    display: flex;
  }
  /* width/min-width(中央ペイン幅)は inline。 */
  .ssg-center-pane {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  /* 0 行時の空状態。 */
  .ssg-empty-state {
    position: sticky;
    left: 0;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ssg-panel-text-faint);
    font-size: 13px;
    user-select: none;
  }
  /* autosize 計測中の overlay + ピル。 */
  .ssg-autosize-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 5;
  }
  .ssg-autosize-pill {
    padding: 8px 14px;
    border-radius: 8px;
    background-color: var(--ssg-pill-bg);
    color: var(--ssg-pill-text);
    font-size: 13px;
    font-weight: 600;
    box-shadow: var(--ssg-pill-shadow);
    user-select: none;
  }

  /* 追加(F-async): グローバルフィルタ適用中のローディング overlay です。autosize overlay と同じ
     作法(シェルに absolute・中央配置・pointer-events:none)で本体へ重ねます。見た目は従来の
     「スピナー + 適用中 NN%」を踏襲しつつ、本体に重ねても読めるよう淡いピル背景を敷きます。
     バーのフロー外に z 方向で配置するため、トップバーの幅/レイアウトから独立します。 */
  .ssg-filter-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 5;
  }
  .ssg-filter-overlay-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background-color: var(--ssg-cell-bg);
    border: 1px solid var(--ssg-line-strong);
    box-shadow: var(--ssg-overlay-chip-shadow);
    color: var(--ssg-readonly-text);
    font-size: 12px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    user-select: none;
  }
  /* 進捗テキストは最大表記("適用中 100%")ぶんの幅を確保し、桁が変わってもチップが伸縮せず
     中央からぶれないようにします(等幅数字 + 固定幅)。 */
  .ssg-filter-overlay-text {
    min-width: 5.5em;
    text-align: center;
  }
  .ssg-filter-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--ssg-line-strong);
    border-top-color: var(--ssg-accent);
    border-radius: 50%;
    animation: ssg-filter-spin 0.7s linear infinite;
  }
  @keyframes ssg-filter-spin {
    to {
      transform: rotate(360deg);
    }
  }
  /* モーション低減設定では回転を止めます(アクセシビリティ)。 */
  @media (prefers-reduced-motion: reduce) {
    .ssg-filter-spinner {
      animation: none;
    }
  }

  /* 追加(モノトーン): 列ドロップ位置のガイド線。near-black 2px + 端ダイヤ(キャレット)で
     「挿入位置」を上質に示します。色/幅/キャップは本クラス、height/left/表示は
     SpreadsheetGrid 側のインライン style + ref(display/left)で制御します。 */
  .ssg-col-drop-indicator {
    width: 2px;
    background-color: var(--ssg-drop-indicator);
  }
  .ssg-col-drop-indicator::before,
  .ssg-col-drop-indicator::after {
    content: '';
    position: absolute;
    left: 50%;
    width: 7px;
    height: 7px;
    background-color: var(--ssg-drop-indicator);
    transform: translateX(-50%) rotate(45deg);
  }
  .ssg-col-drop-indicator::before {
    top: -3px;
  }
  .ssg-col-drop-indicator::after {
    bottom: -3px;
  }

  /* ── カスタムツールチップ(TT-1) ── */
  /* title 属性のブラウザ標準ツールチップを置き換える表示です(Mantine 風・矢印なし)。
     body 直下シングルトン(hooks/useGridTooltip.ts が生成・表示制御)。表示対象は
     data-ssg-tooltip 属性。色はトークン(テーマ対象サーフェス — トークン定義セレクタ
     リストに .ssg-tooltip を含む)。z-index はポップオーバー(1000)より上・
     ドラッグゴースト(9999)より下の 9000。opacity/transform のみ遷移し、非表示中の
     座標移動はアニメしません(left/top は transition 対象外)。 */
  .ssg-tooltip {
    position: fixed;
    z-index: 9000;
    pointer-events: none;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 120ms ease, transform 120ms ease;
    max-width: 260px;
    white-space: pre-line;
    overflow-wrap: break-word;
    line-height: 1.45;
    background-color: var(--ssg-tooltip-bg);
    color: var(--ssg-tooltip-text);
    font-size: 12px;
    font-weight: 500;
    padding: 5px 10px;
    border-radius: 6px;
    box-shadow: var(--ssg-tooltip-shadow);
  }

  .ssg-tooltip--visible {
    opacity: 1;
    transform: translateY(0);
  }
