// 追加: bar のタイトル表示用 style です。
export const gridBarTitleStyle: CSSProperties = {
  fontSize: 13,
  fontWeight: 700,
  color: '#334155',
};

// 追加: 薄い badge / chip 表示用 style です。
export const gridBarChipStyle: CSSProperties = {
