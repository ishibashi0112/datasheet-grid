// 追加: Grid 上部の既定ツールバーです。現時点では Global Filter を主役にしつつ、
//       左側へ件数サマリを薄く出します。
export function DefaultGridTopBar<T>({
  context,
}: DefaultGridTopBarProps<T>) {
