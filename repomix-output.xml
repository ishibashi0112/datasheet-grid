  columnFilters: Record<string, ColumnFilterValue> = {},
  sort: GridSortState = [],
  globalText = '',
) => buildGridState(columnWidths, { globalText, columnFilters }, sort);

describe('isSameGridState', () => {
  it('同一内容は true', () => {
    expect(isSameGridState(st({ a: 100 }), st({ a: 100 }))).toBe(true);
  });

  it('version 違いは false', () => {
