            type: 'cell',
            range: { start: { row: 0, col: 0 }, end: { row: 2, col: 2 } },
          },
          visibleColumns: makeCols(5),
        },
        100,
      ),
    ).toBe('Cells: 9 / Rows: 3');
  });
});

describe('formatGridFilterSummary (4 分岐 + 短縮)', () => {
  it('none', () => {
    expect(
      formatGridFilterSummary({ globalFilterText: '', columnFilterValues: {} }),
    ).toBe('Filter: なし');
  });

  it('global only', () => {
