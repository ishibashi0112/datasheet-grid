    // universe = 全行の g 値。全候補を include すると全行通過し、count===length で
    //   下流 useMemo スキップのため同一参照(引数 order)を返す。
    const universe = Array.from(new Set(rows.map((row) => String(row.g))));
    const value: SetColumnFilterValue = {
      kind: 'set',
