    ).toBe(false);
  });

  it('追加(v2): columns 順序違いは false', () => {
    const a = buildGridState({}, emptyFilters(), [], [{ key: 'a' }, { key: 'b' }]);
    const b = buildGridState({}, emptyFilters(), [], [{ key: 'b' }, { key: 'a' }]);
