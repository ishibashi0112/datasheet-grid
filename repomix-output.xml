                  hoveredRowIndex={hoveredRowIndex}
                  isWholeGridSelected={isWholeGridSelected}
                  enableRowSelection={enableRowSelection}
                  rowSelectionState={rowSelectionState}
                  activeCell={uiState.activeCell}
